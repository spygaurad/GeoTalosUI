{
  "extends": [
    "next/core-web-vitals",  // Next.js recommended rules
    "plugin:@typescript-eslint/recommended"  // TypeScript rules
  ],
  "rules": {
    // Pervasive in the Leaflet/map layer where dynamic typing and runtime
    // requires are intentional; downgraded to warnings so they don't block builds.
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-var-requires": "warn",
    "@typescript-eslint/ban-types": "warn",
    // Allow intentionally-unused names when prefixed with an underscore.
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_" }
    ]
  }
}
